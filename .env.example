# Required: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional: Your player name on Poker Now (default: Clawhi)
POKER_PLAYER_NAME=Clawhi

# Optional: Claude model to use (default: claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: Chrome DevTools Protocol endpoint (default: http://127.0.0.1:18800)
# Launch Chrome with: --remote-debugging-port=18800
CDP_ENDPOINT=http://127.0.0.1:18800
